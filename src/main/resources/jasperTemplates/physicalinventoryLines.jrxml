<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
			  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
			  xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                                  http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
			  name="physicaInventoryLines" pageWidth="842" pageHeight="595" orientation="Landscape"
			  whenNoDataType="BlankPage" columnWidth="842" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0"
			  isFloatColumnFooter="true" whenResourceMissingType="Empty" uuid="8eeca41d-cefe-475b-b89b-f898f69a4087"
			  resourceBundle="physicalinventoryLines">

	<import value="java.time.LocalDate"/>
	<import value="java.time.format.DateTimeFormatter"/>
	<import value="java.text.*"/>

	<parameter name="pi_id" class="java.lang.String" isForPrompting="false"/>
	<parameter name="dateFormat" class="java.lang.String" isForPrompting="false"/>
	<parameter name="decimalFormat" class="java.text.DecimalFormat" isForPrompting="false"/>
	<parameter name="showInDoses" class="java.lang.Boolean" isForPrompting="false"/>

	<queryString language="plsql"><![CDATA[
        with temp as (
            select row_number() over () as rownum
            from stockmanagement.physical_inventory_line_items pil
            INNER JOIN stockmanagement.physical_inventories pi on pi.id = pil.physicalinventoryid
            LEFT JOIN stockmanagement.physical_inventory_line_item_adjustments adj on adj.physicalinventorylineitemid = pil.id
            WHERE pi.id = $P!{pi_id} AND pil.quantity IS NOT NULL
        )
        select max(rownum) as max_row_num,
               o.code as productcode,
               o.fullproductname as productname,
               o.netContent as netContent,
               l.lotcode as lotcode,
               l.expirationdate as expirationdate,
               pil.quantity,
               pil.previousstockonhandwhensubmitted as soh,
               pil.extradata,
               adj.quantity as reasonquantity,
               r.name as reasonname,
               odc.displayname
        from temp, stockmanagement.physical_inventory_line_items pil
        INNER JOIN stockmanagement.physical_inventories pi on pi.id = pil.physicalinventoryid
        INNER JOIN referencedata.orderables o on o.id = pil.orderableid
        INNER JOIN (select id, max(versionnumber) as max_version from referencedata.orderables GROUP BY id) vrs
            ON o.id = vrs.id AND o.versionnumber = vrs.max_version
        INNER JOIN referencedata.program_orderables po ON po.orderableid = o.id
        INNER JOIN referencedata.orderable_display_categories odc ON po.orderabledisplaycategoryid = odc.id
        LEFT JOIN referencedata.lots l on l.id = pil.lotId
        LEFT JOIN stockmanagement.physical_inventory_line_item_adjustments adj on adj.physicalinventorylineitemid = pil.id
        LEFT JOIN stockmanagement.stock_card_line_item_reasons r on r.id = adj.reasonid
        WHERE pi.id = $P!{pi_id} AND pil.quantity IS NOT NULL
        GROUP BY o.code, o.fullproductname, o.netContent, l.lotcode, l.expirationdate, pil.quantity,
                 pil.previousstockonhandwhensubmitted, pil.extradata, adj.quantity, adj.id, r.name, odc.displayname, odc.displayorder
        ORDER BY odc.displayorder, o.code, l.lotcode NULLS FIRST
    ]]></queryString>

	<field name="productcode" class="java.lang.String"/>
	<field name="productname" class="java.lang.String"/>
	<field name="lotcode" class="java.lang.String"/>
	<field name="expirationdate" class="java.lang.String"/>
	<field name="netContent" class="java.lang.Integer"/>
	<field name="quantity" class="java.lang.Integer"/>
	<field name="soh" class="java.lang.Integer"/>
	<field name="reasonquantity" class="java.lang.Integer"/>
	<field name="reasonname" class="java.lang.String"/>
	<field name="extradata" class="java.lang.String"/>
	<field name="max_row_num" class="java.lang.Integer"/>
	<field name="displayname" class="java.lang.String"/>

	<variable name="quantitySumValue" class="java.lang.Integer" resetType="Group" resetGroup="productGroup" calculation="Sum">
		<variableExpression><![CDATA[($V{lineItemGroup_COUNT} == 1) ? $F{quantity} : 0]]></variableExpression>
	</variable>
	<variable name="sohSumValue" class="java.lang.Integer" resetType="Group" resetGroup="productGroup" calculation="Sum">
		<variableExpression><![CDATA[($V{lineItemGroup_COUNT} == 1) ? $F{soh} : 0]]></variableExpression>
	</variable>

	<!-- Group by product+lot (line item) -->
	<group name="lineItemGroup">
		<groupExpression><![CDATA[$F{productcode} + ($F{lotcode} == null ? "" : $F{lotcode})]]></groupExpression>
	</group>

	<!-- Group by program -->
	<group name="product_program_group">
		<groupExpression><![CDATA[$F{displayname}]]></groupExpression>
		<groupHeader>
			<band height="25">
				<textField>
					<reportElement x="10" y="0" width="822" height="25" backcolor="#F2F2F2"/>
					<textElement verticalAlignment="Middle">
						<font size="8" isBold="true" fontName="DejaVu Sans" pdfFontName="DejaVuSans.ttf"/>
					</textElement>
					<textFieldExpression><![CDATA[$F{displayname}]]></textFieldExpression>
				</textField>
			</band>
		</groupHeader>
	</group>

	<!-- Group by product -->
	<group name="productGroup">
		<groupExpression><![CDATA[$F{productcode} + $F{productname}]]></groupExpression>
		<groupHeader>
			<band height="25">
				<textField evaluationTime="Group" evaluationGroup="productGroup">
					<reportElement x="610" y="0" width="90" height="25"/>
					<textElement textAlignment="Right">
						<font size="8" isBold="true" fontName="DejaVu Sans" pdfFontName="DejaVuSans.ttf"/>
					</textElement>
					<textFieldExpression><![CDATA[
                        $V{quantitySumValue} == null ? "" :
                        ($P{showInDoses}
                            ? $P{decimalFormat}.format($V{quantitySumValue}).toString()
                            : ($V{quantitySumValue} / ($F{netContent} == null ? 1 : $F{netContent}))
                              + " (" + $R{label.quantity.prefix, fontName=DejaVu Sans, pdfFontName=DejaVuSans.ttf}
                              + ($V{quantitySumValue} % ($F{netContent} == null ? 1 : $F{netContent})) + ")"
                        )
                    ]]></textFieldExpression>
				</textField>

				<textField evaluationTime="Group" evaluationGroup="productGroup">
					<reportElement x="520" y="0" width="90" height="25"/>
					<textElement textAlignment="Right">
						<font size="8" fontName="DejaVu Sans" pdfFontName="DejaVuSans.ttf"/>
					</textElement>
					<textFieldExpression><![CDATA[
                        $V{sohSumValue} == null ? "" :
                        ($P{showInDoses}
                            ? $P{decimalFormat}.format($V{sohSumValue}).toString()
                            : ($V{sohSumValue} / ($F{netContent} == null ? 1 : $F{netContent}))
                              + " (" + $R{label.quantity.prefix, fontName=DejaVu Sans, pdfFontName=DejaVuSans.ttf}
                              + ($V{sohSumValue} % ($F{netContent} == null ? 1 : $F{netContent})) + ")"
                        )
                    ]]></textFieldExpression>
				</textField>
			</band>
		</groupHeader>
	</group>

	<!-- Column header -->
	<columnHeader>
		<band height="25">
			<staticText>
				<reportElement x="700" y="0" width="132" height="25" backcolor="#CCCCCC"/>
				<textElement>
					<font size="9" fontName="DejaVu Sans" pdfFontName="DejaVuSans.ttf"/>
				</textElement>
				<text><![CDATA[$R{label.itemizedReasons, fontName=DejaVu Sans, pdfFontName=DejaVuSans.ttf}]]></text>
			</staticText>

			<textField>
				<reportElement x="610" y="0" width="92" height="25" backcolor="#CCCCCC"/>
				<textElement>
					<font size="9" fontName="DejaVu Sans" pdfFontName="DejaVuSans.ttf"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{showInDoses}
                    ? $R{label.currentStock.doses, fontName=DejaVu Sans, pdfFontName=DejaVuSans.ttf}
                    : $R{label.currentStock.packs, fontName=DejaVu Sans, pdfFontName=DejaVuSans.ttf}
                ]]></textFieldExpression>
			</textField>

			<textField>
				<reportElement x="520" y="0" width="90" height="25" backcolor="#CCCCCC"/>
				<textElement>
					<font size="9" fontName="DejaVu Sans" pdfFontName="DejaVuSans.ttf"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{showInDoses}
                    ? $R{label.soh.doses, fontName=DejaVu Sans, pdfFontName=DejaVuSans.ttf}
                    : $R{label.soh.packs, fontName=DejaVu Sans, pdfFontName=DejaVuSans.ttf}
                ]]></textFieldExpression>
			</textField>
		</band>
	</columnHeader>
	<detail>
		<band height="25" splitType="Stretch">
			<textField evaluationTime="Group" evaluationGroup="lineItemGroup" isBlankWhenNull="true">
				<reportElement x="244" y="0" width="72" height="25" printWhenGroupChanges="lineItemGroup" uuid="c649aa2d-900a-4d7f-94f7-0d072c516c0a">
					<printWhenExpression><![CDATA[$V{lineItemGroup_COUNT} == 1]]></printWhenExpression>
				</reportElement>
				<box padding="3">
					<topPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement>
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[($F{lotcode} == null) ? $R{label.noLotDefined} : $F{lotcode}]]></textFieldExpression>
			</textField>
			<textField evaluationTime="Group" evaluationGroup="lineItemGroup" isBlankWhenNull="true">
				<reportElement x="316" y="0" width="102" height="25" printWhenGroupChanges="lineItemGroup" uuid="0e217f2e-f7ca-4c05-b9d2-f13ec6cf38db">
					<printWhenExpression><![CDATA[$V{lineItemGroup_COUNT} == 1]]></printWhenExpression>
				</reportElement>
				<box padding="3">
					<topPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Right">
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[DateTimeFormatter.ofPattern($P{dateFormat}).format(LocalDate.parse($F{expirationdate}))]]></textFieldExpression>
			</textField>
			<textField evaluationTime="Group" evaluationGroup="lineItemGroup" isBlankWhenNull="true">
				<reportElement x="418" y="0" width="102" height="25" printWhenGroupChanges="lineItemGroup" uuid="a7672f9a-30bd-4bf9-96af-324baa7e2280">
					<printWhenExpression><![CDATA[$V{lineItemGroup_COUNT} == 1]]></printWhenExpression>
				</reportElement>
				<box padding="3">
					<topPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement>
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[new org.json.JSONObject($F{extradata}).optString("vvmStatus", "")]]></textFieldExpression>
			</textField>
			<textField evaluationTime="Group" evaluationGroup="lineItemGroup">
				<reportElement x="520" y="0" width="90" height="25" printWhenGroupChanges="lineItemGroup" forecolor="#848484" uuid="547fa08c-24e6-4617-aa94-09384a952a19">
					<printWhenExpression><![CDATA[$V{lineItemGroup_COUNT} == 1]]></printWhenExpression>
				</reportElement>
				<box padding="3">
					<topPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Right">
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{soh} == null ? "" :
                    (
                        $P{showInDoses}
                          ? $P{decimalFormat}.format($F{soh}).toString()
                          : (
                              ($F{soh} / ($F{netContent} == null ? 1 : $F{netContent}))
                              + " (" + $R{label.quantity.prefix} + ($F{soh} % ($F{netContent} == null ? 1 : $F{netContent})) + ")"
                            )
                    )]]></textFieldExpression>
			</textField>
			<textField evaluationTime="Group" evaluationGroup="lineItemGroup">
				<reportElement x="610" y="0" width="90" height="25" printWhenGroupChanges="lineItemGroup" uuid="a2c8fc54-7cdc-442a-9ced-608a01ef270b">
					<printWhenExpression><![CDATA[$V{lineItemGroup_COUNT} == 1]]></printWhenExpression>
				</reportElement>
				<box padding="3">
					<topPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Right">
					<font size="8" isBold="true" pdfFontName="Helvetica-Bold"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{quantity} == null ? "" :
                    (
                        $P{showInDoses}
                          ? $P{decimalFormat}.format($F{quantity}).toString()
                          : (
                              ($F{quantity} / ($F{netContent} == null ? 1 : $F{netContent}))
                              + " (" + $R{label.quantity.prefix} + ($F{quantity} % ($F{netContent} == null ? 1 : $F{netContent})) + ")"
                            )
                    )]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement x="700" y="0" width="132" height="25" uuid="86886d4d-e188-4bbf-bfc7-113325f40773"/>
				<box padding="3">
					<topPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement>
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{reasonquantity} != null ? ($P{decimalFormat}.format($F{reasonquantity}).toString() + " " + $F{reasonname}) : ""]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="82" y="0" width="162" height="25" uuid="fa240131-8b7e-4a65-98df-10999828a02c"/>
				<box padding="3">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
			</staticText>
			<staticText>
				<reportElement x="316" y="0" width="102" height="25" uuid="ebc8760d-d268-41e6-aae9-fb96082fe7bd"/>
				<box padding="3">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
			</staticText>
			<staticText>
				<reportElement x="520" y="0" width="90" height="25" uuid="60e82caa-8c9f-4334-a7ab-e07f3101c1a7"/>
				<box padding="3">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
			</staticText>
			<staticText>
				<reportElement x="10" y="0" width="822" height="25" uuid="2d28b427-6b18-4024-b05d-2e5c03c6b5fb"/>
				<box padding="3">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
			</staticText>
			<staticText>
				<reportElement x="10" y="0" width="822" height="25" uuid="6071707f-3f5f-4ed6-ac1a-a65c8e4d2cb7">
					<printWhenExpression><![CDATA[$V{REPORT_COUNT} == $F{max_row_num}]]></printWhenExpression>
				</reportElement>
				<box padding="3">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
			</staticText>
		</band>
	</detail>
</jasperReport>