<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
			  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
			  xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                                  http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
			  name="StockCardSummary" pageWidth="595" pageHeight="842" columnWidth="595"
			  leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0"
			  whenResourceMissingType="Empty" uuid="d0829c7a-bf73-4e6e-9b5a-1735ab6c4d7d"
			  resourceBundle="stockCardSummary">

	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="One Empty Record"/>
	<property name="com.jaspersoft.studio.unit." value="pixel"/>
	<property name="com.jaspersoft.studio.unit.pageHeight" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.pageWidth" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.topMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.bottomMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.leftMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.rightMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.columnWidth" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.columnSpacing" value="pixel"/>

	<import value="org.openlmis.stockmanagement.domain.card.*"/>
	<import value="org.openlmis.stockmanagement.dto.*"/>
	<import value="java.time.LocalDate"/>
	<import value="java.time.format.DateTimeFormatter"/>
	<import value="java.time.ZonedDateTime"/>
	<import value="java.text.DecimalFormat"/>
	<import value="net.sf.jasperreports.engine.data.*"/>

	<!-- Стили таблицы -->
	<style name="Table_TH" mode="Opaque" backcolor="#F0F8FF">
		<box><pen lineWidth="0.5" lineColor="#000000"/></box>
	</style>
	<style name="Table_CH" mode="Opaque" backcolor="#BFE1FF">
		<box><pen lineWidth="0.5" lineColor="#000000"/></box>
	</style>
	<style name="Table_TD" mode="Opaque" backcolor="#FFFFFF">
		<box><pen lineWidth="0.5" lineColor="#000000"/></box>
	</style>
	<style name="Table 1_TH" mode="Opaque" backcolor="#F0F8FF">
		<box><pen lineWidth="0.5" lineColor="#000000"/></box>
	</style>
	<style name="Table 1_CH" mode="Opaque" backcolor="#BFE1FF">
		<box><pen lineWidth="0.5" lineColor="#000000"/></box>
	</style>
	<style name="Table 1_TD" mode="Opaque" backcolor="#FFFFFF">
		<box><pen lineWidth="0.5" lineColor="#000000"/></box>
	</style>

	<!-- Поддатасет -->
	<subDataset name="summaryDataset" uuid="ae304191-3438-4962-8ef9-3c2d74be4f9a">
		<parameter name="showProgram" class="java.lang.Boolean">
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="showFacility" class="java.lang.Boolean">
			<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
		</parameter>
		<parameter name="showLot" class="java.lang.Boolean"/>
		<parameter name="dateFormat" class="java.lang.String" isForPrompting="false"/>
		<parameter name="decimalFormat" class="java.text.DecimalFormat" isForPrompting="false"/>
		<field name="facility" class="org.openlmis.stockmanagement.dto.referencedata.FacilityDto"/>
		<field name="program" class="org.openlmis.stockmanagement.dto.referencedata.ProgramDto"/>
		<field name="orderable" class="org.openlmis.stockmanagement.dto.referencedata.OrderableDto"/>
		<field name="stockOnHand" class="java.lang.Integer"/>
		<field name="lastUpdate" class="java.time.LocalDate"/>
		<field name="lot" class="org.openlmis.stockmanagement.dto.referencedata.LotDto"/>
	</subDataset>

	<!-- Параметры -->
	<parameter name="program" class="org.openlmis.stockmanagement.dto.referencedata.ProgramDto" isForPrompting="false"/>
	<parameter name="facility" class="org.openlmis.stockmanagement.dto.referencedata.FacilityDto" isForPrompting="false"/>
	<parameter name="stockCardSummaries" class="java.util.List" isForPrompting="false"/>
	<parameter name="showProgram" class="java.lang.Boolean" isForPrompting="false"/>
	<parameter name="showFacility" class="java.lang.Boolean" isForPrompting="false"/>
	<parameter name="showLot" class="java.lang.Boolean" isForPrompting="false"/>
	<parameter name="dateTimeFormat" class="java.lang.String" isForPrompting="false"/>
	<parameter name="dateFormat" class="java.lang.String" isForPrompting="false"/>
	<parameter name="decimalFormat" class="java.text.DecimalFormat" isForPrompting="false"/>

	<!-- Background -->
	<background><band splitType="Stretch"/></background>

	<!-- Title -->
	<title>
		<band height="124" splitType="Stretch">
			<textField>
				<reportElement x="0" y="20" width="595" height="50" uuid="ecab56ef-a62f-486f-bc7d-c1431467efc4"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="DejaVu Sans" pdfFontName="DejaVuSans.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true" size="26" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$R{title.stockCardSummaryReport}]]></textFieldExpression>
			</textField>
		</band>
	</title>

	<!-- Page Header -->
	<pageHeader>
		<band height="30" splitType="Stretch">
			<printWhenExpression><![CDATA[new Boolean($V{PAGE_NUMBER}.intValue() == 1)]]></printWhenExpression>

			<!-- Facility Label -->
			<textField>
				<reportElement x="0" y="0" width="77" height="30" uuid="d88076e4-ce9f-4886-a172-855275a4a5e7"/>
				<textElement textAlignment="Right">
					<font fontName="DejaVu Sans" pdfFontName="DejaVuSans.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$R{label.facility} + ":"]]></textFieldExpression>
			</textField>

			<!-- Facility Name -->
			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
				<reportElement x="90" y="0" width="74" height="30" uuid="68d8d341-d519-4cd5-adaf-845085a2b343"/>
				<textElement>
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{facility}.getName()]]></textFieldExpression>
			</textField>

			<!-- Facility Code Label -->
			<textField>
				<reportElement x="151" y="0" width="74" height="30" uuid="e70d1a9b-4bcc-460c-8ffe-c238d8d4e9af"/>
				<textElement textAlignment="Right">
					<font fontName="DejaVu Sans" pdfFontName="DejaVuSans.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$R{label.facilityCode} + ":"]]></textFieldExpression>
			</textField>

			<!-- Facility Code Value -->
			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
				<reportElement x="230" y="0" width="74" height="30" uuid="e28722c1-aff1-4167-af88-1d9b88dc2c81"/>
				<textElement>
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{facility}.getCode()]]></textFieldExpression>
			</textField>

			<!-- Program Label -->
			<textField>
				<reportElement x="299" y="0" width="41" height="30" uuid="f932b782-290f-45d4-9fdf-f2cc21d3088c"/>
				<textElement textAlignment="Right">
					<font fontName="DejaVu Sans" pdfFontName="DejaVuSans.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$R{label.program} + ":"]]></textFieldExpression>
			</textField>

			<!-- Program Name -->
			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
				<reportElement x="350" y="0" width="74" height="30" uuid="090f268a-9013-48d7-bf4c-2d082ce82426"/>
				<textElement>
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{program}.getName()]]></textFieldExpression>
			</textField>

			<!-- Program Code Label -->
			<textField>
				<reportElement x="424" y="0" width="63" height="30" uuid="dbb8c60d-f18c-4662-82a9-1469ba5ee29b"/>
				<textElement textAlignment="Right">
					<font fontName="DejaVu Sans" pdfFontName="DejaVuSans.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$R{label.programCode} + ":"]]></textFieldExpression>
			</textField>

			<!-- Program Code Value -->
			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
				<reportElement x="493" y="0" width="74" height="30" uuid="1155efb4-d80b-4867-bc2c-4708e21299cb"/>
				<textElement>
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{program}.getCode()]]></textFieldExpression>
			</textField>
		</band>
	</pageHeader>

	<!-- Column Header, Page Footer и Summary остались как в твоем исходнике -->

</jasperReport>