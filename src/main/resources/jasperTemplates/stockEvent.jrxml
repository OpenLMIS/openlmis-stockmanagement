			<textField isBlankWhenNull="true" isStretchWithOverflow="true">
				<reportElement stretchType="RelativeToBandHeight" x="680" y="0" width="70" height="22" uuid="a2c8fc54-7cdc-442a-9ced-608a01ef270b"/>
				<box padding="3">
