    <style name="BaseStyle" isDefault="true" fontName="DejaVu Sans" fontSize="10"/>
	<parameter name="stockEventId" class="java.lang.String" isForPrompting="false"/>
	<parameter name="dateFormat" class="java.lang.String" isForPrompting="false"/>
	<parameter name="dateTimeFormat" class="java.lang.String" isForPrompting="false"/>
	<parameter name="timeZoneId" class="java.lang.String" isForPrompting="false"/>
	<parameter name="decimalFormat" class="java.text.DecimalFormat" isForPrompting="false"/>
	<parameter name="showInDoses" class="java.lang.Boolean" isForPrompting="false"/>
	<parameter name="headerTemplate" class="net.sf.jasperreports.engine.JasperReport"/>
	<queryString language="plsql">
		<![CDATA[
WITH RECURSIVE
ordered_items AS (
    SELECT
        scli.id,
        scli.stockcardid,
        scli.quantity,
        scli.sourceid,
        scli.destinationid,
        scli.reasonid,
        sclir.reasontype,
        ROW_NUMBER() OVER (
            PARTITION BY scli.stockcardid
            ORDER BY scli.occurreddate, scli.processeddate, scli.id
        ) AS rn
    FROM stockmanagement.stock_card_line_items scli
    LEFT JOIN stockmanagement.stock_card_line_item_reasons sclir
      ON sclir.id = scli.reasonid
    WHERE scli.stockcardid IN (
        SELECT DISTINCT stockcardid
        FROM stockmanagement.stock_card_line_items
        WHERE origineventid = $P{stockEventId}::uuid
    )
),
running_soh AS (
    SELECT oi.*,
        CASE
            WHEN oi.reasonid IS NULL AND oi.sourceid IS NULL AND oi.destinationid IS NULL
                THEN oi.quantity
            WHEN oi.sourceid IS NOT NULL OR oi.reasontype = 'CREDIT'
                THEN oi.quantity
            ELSE -oi.quantity
        END AS soh
    FROM ordered_items oi
    WHERE oi.rn = 1

    UNION ALL

    SELECT oi.*,
        CASE
            WHEN oi.reasonid IS NULL AND oi.sourceid IS NULL AND oi.destinationid IS NULL
                THEN oi.quantity
            WHEN oi.sourceid IS NOT NULL OR oi.reasontype = 'CREDIT'
                THEN rs.soh + oi.quantity
            ELSE rs.soh - oi.quantity
        END AS soh
    FROM running_soh rs
    JOIN ordered_items oi
      ON oi.stockcardid = rs.stockcardid
     AND oi.rn = rs.rn + 1
)
SELECT
    se.documentnumber           AS documentnumber,
    se.processeddate            AS processeddate,
    se.signature                AS signature,
    se.eventorigin              AS eventorigin,
    f.name                      AS facility,
    p.name                      AS program,
    u.firstname                 AS firstname,
    u.lastname                  AS lastname,
    o.code                      AS productcode,
    o.fullproductname           AS productname,
    o.netcontent                AS netcontent,
    l.lotcode                   AS lotcode,
    scli.occurreddate           AS occurreddate,
    COALESCE(source_facility.name, source_organization.name)            AS source,
    scli.sourcefreetext         AS sourcefreetext,
    COALESCE(destination_facility.name, destination_organization.name)  AS destination,
    scli.destinationfreetext    AS destinationfreetext,
    sclir.name                  AS reasonname,
    scli.reasonfreetext         AS reasonfreetext,
    scli.quantity               AS quantity,
    rs.soh                      AS stockonhand
FROM stockmanagement.stock_card_line_items scli
LEFT JOIN stockmanagement.stock_events se ON se.id = scli.origineventid
LEFT JOIN stockmanagement.stock_cards sc ON sc.id = scli.stockcardid
LEFT JOIN referencedata.facilities f ON f.id = se.facilityid
LEFT JOIN stockmanagement.nodes source_nodes ON source_nodes.id = scli.sourceid
LEFT JOIN referencedata.facilities source_facility ON source_facility.id = source_nodes.referenceid AND source_nodes.isrefdatafacility IS TRUE
LEFT JOIN stockmanagement.organizations source_organization ON source_organization.id = source_nodes.referenceid AND source_nodes.isrefdatafacility IS FALSE
LEFT JOIN stockmanagement.nodes destination_nodes ON destination_nodes.id = scli.destinationid
LEFT JOIN referencedata.facilities destination_facility ON destination_facility.id = destination_nodes.referenceid AND destination_nodes.isrefdatafacility IS TRUE
LEFT JOIN stockmanagement.organizations destination_organization ON destination_organization.id = destination_nodes.referenceid AND destination_nodes.isrefdatafacility IS FALSE
LEFT JOIN referencedata.programs p ON p.id = se.programid
LEFT JOIN referencedata.users u ON u.id = se.userid
LEFT JOIN referencedata.orderables o ON o.id = sc.orderableid
LEFT JOIN referencedata.lots l ON l.id = sc.lotid
LEFT JOIN stockmanagement.stock_card_line_item_reasons sclir ON sclir.id = scli.reasonid
LEFT JOIN running_soh rs ON rs.id = scli.id
WHERE se.id = $P{stockEventId}::uuid
ORDER BY o.code, l.lotcode NULLS FIRST, scli.occurreddate, scli.processeddate
        ]]>
	</queryString>
